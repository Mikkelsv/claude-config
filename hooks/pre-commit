#!/bin/bash
# Auto-bump config version on meaningful changes
# This hook detects staged changes to rules, commands, skills, scripts, or templates
# and bumps the patch version in Claude/config-version.json.

TRACKED_DIRS="dotclaude/rules dotclaude/commands dotclaude/skills Claude/scripts Claude/skills Claude/templates"

CHANGED=false
for dir in $TRACKED_DIRS; do
    if git diff --cached --name-only | grep -q "^$dir/"; then
        CHANGED=true
        break
    fi
done

if [ "$CHANGED" = false ]; then
    exit 0
fi

VERSION_FILE="Claude/config-version.json"

if [ ! -f "$VERSION_FILE" ]; then
    exit 0
fi

CURRENT=$(grep '"version"' "$VERSION_FILE" | sed 's/.*"\([0-9]*\.[0-9]*\.[0-9]*\)".*/\1/')
if [ -z "$CURRENT" ]; then
    exit 0
fi

IFS='.' read -r MAJOR MINOR PATCH <<< "$CURRENT"
PATCH=$((PATCH + 1))
NEW_VERSION="$MAJOR.$MINOR.$PATCH"
TODAY=$(date +%Y-%m-%d)

# Update using PowerShell for reliable JSON handling on Windows
powershell.exe -NoProfile -Command "
  \$json = Get-Content '$VERSION_FILE' -Raw | ConvertFrom-Json
  \$json.version = '$NEW_VERSION'
  \$json.lastUpdated = '$TODAY'
  \$json | ConvertTo-Json -Depth 10 | Set-Content '$VERSION_FILE' -Encoding UTF8
"

git add "$VERSION_FILE"
